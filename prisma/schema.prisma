generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ReservationState {
  RESERVED
  SHIPPING
  SHIPPED
  RELEASED
  RETURNED
  CANCELLED
}

enum UserRole {
  OWNER
  PARTNER
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?   // Nullable for OAuth users
  role          UserRole  @default(PARTNER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  movements StockMovement[]
  accounts  Account[]
  sessions  Session[]
  reservations Reservation[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String?
  categoryId  String?
  isArchived  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  category Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  sku          String?  @unique
  size         String?  // e.g. "XS", "S", "M", "L", "XL", "XXL", "Free Size"
  color        String?  // e.g. "Black", "White", "Navy"
  fabric       String?  // e.g. "Cotton", "Polyester", "Linen"
  costPrice    Decimal  @db.Decimal(10, 2) @default(0)  // Cost to buy from supplier
  price        Decimal  @db.Decimal(10, 2)              // Selling price to customer
  salePrice    Decimal? @db.Decimal(10, 2)              // Promotional price
  currentStock Int      @default(0)
  reservedStock Int     @default(0)
  lowStockAt   Int      @default(5)
  isArchived   Boolean  @default(false)
  damaged      Boolean  @default(false)                 // Whether this variant is marked as damaged
  damageNote   String?                                  // Reason or description of damage
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements StockMovement[]
  batchMovements BatchMovement[]
  reservations Reservation[]

  @@index([productId])
  @@map("product_variants")
}

model StockMovement {
  id        String       @id @default(cuid())
  variantId String
  type      MovementType
  quantity  Int
  priceAtMovement Decimal?     @db.Decimal(10, 2)
  costPriceAtMovement Decimal? @db.Decimal(10, 2)
  note      String?
  userId    String?
  batchId   String?
  createdAt DateTime     @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  user    User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  batch   Batch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([createdAt])
  @@index([variantId, type, createdAt])
  @@map("stock_movements")
}

model Batch {
  id           String          @id @default(cuid())
  supplierName String?
  purchaseDate DateTime?
  totalCost    Decimal?        @db.Decimal(10, 2)
  estimatedQty Int?
  actualQty    Int?
  damagedQty   Int?            @default(0)
  category     String?
  notes        String?
  createdAt    DateTime        @default(now())

  movements    BatchMovement[]
  stockMovements StockMovement[]

  @@map("batches")
}

model BatchMovement {
  id          String   @id @default(cuid())
  batchId     String
  variantId   String
  quantity    Int
  costPerUnit Decimal? @db.Decimal(10, 2)

  batch       Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([batchId])
  @@index([variantId])
  @@map("batch_movements")
}

model Reservation {
  id           String           @id @default(cuid())
  variantId    String
  quantity     Int
  state        ReservationState @default(RESERVED)
  customerName String?
  reservedAt   DateTime         @default(now())
  shippingAt   DateTime?
  shippedAt    DateTime?
  releasedAt   DateTime?
  returnedAt   DateTime?
  cancelledAt  DateTime?
  updatedBy    String?

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  user    User?          @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([state])
  @@index([reservedAt])
  @@map("reservations")
}
